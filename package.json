{
  "name": "pkg-sentinel",
  "version": "0.1.1",
  "description": "Production-quality npm supply-chain security CLI — trust analysis, health scoring, install script inspection, typosquatting detection, and AI-powered risk summaries.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pkg-sentinel": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "npm",
    "security",
    "supply-chain",
    "audit",
    "trust",
    "typosquatting",
    "cli",
    "static-analysis",
    "ast",
    "install-scripts",
    "package-health",
    "vulnerability",
    "devtools"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hemantjawale/pkg-sentinel.git"
  },
  "bugs": {
    "url": "https://github.com/hemantjawale/pkg-sentinel/issues"
  },
  "homepage": "https://github.com/hemantjawale/pkg-sentinel#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "tar": "^7.5.19"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/cli-progress": "^3.11.5",
    "@types/node": "^20.14.0",
    "@types/tar": "^6.1.13",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.5.0",
    "msw": "^2.3.0",
    "prettier": "^3.3.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
